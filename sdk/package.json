{
  "name": "@grip-protocol/sdk",
  "version": "0.2.0",
  "description": "Unified PayClaw + Grip Protocol SDK — Payment infrastructure for AI agents",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit"
  },
  "keywords": [
    "ai", "agents", "payments", "pix", "usdc", "base",
    "grip-protocol", "payclaw", "escrow", "session-keys"
  ],
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.12.0",
    "tsup": "^8.0.2",
    "typescript": "^5.4.3",
    "vitest": "^1.4.0",
    "msw": "^2.2.13"
  },
  "peerDependencies": {
    "typescript": ">=5.0.0"
  }
}
